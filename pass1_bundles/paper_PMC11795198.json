    {
      "id": "Paper:PMC11795198",
      "class": "Paper",
      "name": "Genetics in Congenital Adrenal Hyperplasia Due to 21-Hydroxylase Deficiency and Clinical Implications",
      "synonyms": [],
      "symbol": null,
      "brand_names": [],
      "source": "extracted",
      "canonical_id": "PMC11795198",
      "umls_id": null,
      "hgnc_id": null,
