  ],
  "evidence_entities": [
    {
      "id": "PMC11795198:abstract:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "abstract_0",
      "text": "Of all congenital adrenal hyperplasia (CAH), 95% to 99% is 21-hydroxylase deficiency (21OHD), an autosomal recessive disease.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11795198:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "abstract_1",
      "text": "21OHD is due to an insufficiency of 21-hydroxylase enzyme, which is encoded by the CYP21A2 gene and involved in cortisol and aldosterone production.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11795198:introduction:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "introduction_0",
      "text": "Through a negative feedback system, the lack of cortisol synthesis causes an increase in adrenocorticotropic hormone (ACTH) that determines hyperplasia of the adrenal cortex due to the continuous overstimulation and hypersecretion of precursors upstream of the enzyme defect.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11795198:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "introduction_1",
      "text": "The 21OH enzyme converts 17\u03b1-hydroxyprogesterone to 11-deoxycortisol and progesterone to deoxycorticosterone.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11795198:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "introduction_2",
      "text": "Several studies on adrenal cortex function have established that the zona glomerulosa is responsible for the production of aldosterone, while the zona fasciculata is responsible for the production of cortisol.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11795198:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "introduction_3",
      "text": "46,XX children with classic CAH have external virilized genitals while both 46,XX and 46,XY children with SW CAH will succumb to adrenal crisis if not diagnosed during the neonatal period.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11795198:introduction:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11795198",
      "text_span_id": "introduction_4",
      "text": "The serum 17\u03b1-hydroxyprogesterone (17OHP) concentration is utilized as the principal marker for 21OHD, since CAH due to 21OHD is detected in NBS programs using 17OHP concentration measurements in dried blood spots.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    }
  ],
