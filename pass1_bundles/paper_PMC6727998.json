  "evidence_entities": [
    {
      "id": "PMC6727998:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6727998",
      "text_span_id": "abstract_1",
      "text": "Tactile hypoesthesia observed in patients with myofascial pain syndrome (MPS) is sometimes reversible when pain is relieved by trigger point injections (TPIs).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC6727998:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6727998",
      "text_span_id": "results_1",
      "text": "A reduction in the size of hypoesthetic area with TPI was observed in 27 (58.7%) patients.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC6727998:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6727998",
      "text_span_id": "results_2",
      "text": "All the 27 patients experienced a reduction in pain intensity by more than 50% in a numerical rating scale score through TPI therapy.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC6727998:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6727998",
      "text_span_id": "results_3",
      "text": "Complete disappearance of tactile hypoesthesia after TPI therapy was observed in 6 of the 27 patients.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC6727998:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6727998",
      "text_span_id": "discussion_1",
      "text": "Several brain imaging studies have shown that the activity of the primary somatosensory cortex decreases along with a decline in touch sensation.",
      "confidence": 0.8,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC6727998:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6727998",
      "text_span_id": "discussion_2",
      "text": "Such inhibition of neuronal activity in the somatosensory cortex induced by ongoing afferent nociceptive input from MTrP may underlie the reversible tactile hypoesthesia in patients with MPS.",
      "confidence": 0.7,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    }
  ],
