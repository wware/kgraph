  "evidence_entities": [
    {
      "id": "PMC_extracted:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "methods_1",
      "text": "Forty-six consecutive patients with MTrP were enrolled in this study. We closely observed changes in areas of tactile hypoesthesia in patients who had tactile hypoesthesia at the first visit, and throughout TPI therapy.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": "observational study",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_1",
      "text": "A reduction in the size of hypoesthetic area with TPI was observed in 27 (58.7%) patients. All the 27 patients experienced a reduction in pain intensity by more than 50% in a numerical rating scale score through TPI therapy.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": "observational study",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_2",
      "text": "Complete disappearance of tactile hypoesthesia after TPI therapy was observed in 6 of the 27 patients.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": "observational study",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_3",
      "text": "Myofascial trigger points were located in the muscles in the vicinity of ipsilateral cutaneous dermatomes to which the hypoesthetic areas belonged.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": "observational study",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_4",
      "text": "Thirty-four (74%) of 46 patients with MTrP had tactile hypoesthesia.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": "observational study",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "discussion_1",
      "text": "Such inhibition of neuronal activity in the somatosensory cortex induced by ongoing afferent nociceptive input from MTrP may underlie the reversible tactile hypoesthesia in patients with MPS.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": "observational study",
      "source": "extracted"
    }
