      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "introduction_1",
      "text": "In pituitary-induced Cushing (PC), excessive secretion of ACTH stimulates the adrenal glands to produce cortisol.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
