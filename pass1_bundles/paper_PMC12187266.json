      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "introduction_2",
      "text": "Ectopic CS (EC) occurs when tumors located outside the pituitary gland, such as those in the pancreas, lungs or thyroid produce ACTH.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
