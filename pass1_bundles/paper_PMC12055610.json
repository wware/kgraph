      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "adverse_effects_1",
      "text": "Hypocortisolism-related adverse events (mostly reported as adrenal insufficiency or glucocorticoid deficiency) occurred in 70/138 (51%) of patients across the entire study.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Drug Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:adverse_effects:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "adverse_effects_2",
      "text": "Inhibition of 11-beta-hydroxylase is associated with the accumulation of adrenal steroid precursors and increased testosterone; in female participants, hirsutism and acne were reported in 11% and 12%, respectively.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Drug Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
