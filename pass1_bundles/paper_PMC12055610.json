      "text_span_id": "background_1",
      "text": "Endogenous Cushing syndrome denotes a group of rare diseases resulting from the body's over-excretion of cortisol",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
