  "evidence_entities": [
    {
      "id": "PMC12055610:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12055610",
      "text_span_id": "background_1",
      "text": "Endogenous Cushing syndrome denotes a group of rare diseases resulting from the body's over-excretion of cortisol. It can be characterised as adrenocorticotrophic hormone (ACTH)\u2013dependent or independent. The most common form of ACTH-dependent Cushing syndrome is Cushing disease, where there is a pituitary tumour that secretes ACTH, leading to an overproduction of cortisol.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12055610:mechanism:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12055610",
      "text_span_id": "mechanism_1",
      "text": "Osilodrostat is a potent inhibitor of 11-beta-hydroxylase, an enzyme that catalyses cortisol biosynthesis in the adrenal gland.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12055610:clinical_trials:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12055610",
      "text_span_id": "clinical_trials_1",
      "text": "More patients who continued osilodrostat maintained a complete response without any dose increases during this period compared with those on placebo (86.1% versus 29.4%).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12055610:adverse_effects:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12055610",
      "text_span_id": "adverse_effects_1",
      "text": "Hypocortisolism-related adverse events (mostly reported as adrenal insufficiency or glucocorticoid deficiency) occurred in 70/138 (51%) of patients across the entire study.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12055610:adverse_effects:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12055610",
      "text_span_id": "adverse_effects_2",
      "text": "Inhibition of 11-beta-hydroxylase is associated with the accumulation of adrenal steroid precursors and increased testosterone; in female participants, hirsutism and acne were reported in 11% and 12%, respectively.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    }
