      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "adverse_effects_3",
      "text": "A decrease in serum potassium concentration was observed in some patients, with 7 (5%) patients developing severe hypokalaemia.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Drug Review",
      "eco_type": null,
      "source": "extracted"
    },
