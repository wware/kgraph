    {
      "id": "PMC12750049:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12750049",
      "text_span_id": "results_1",
      "text": "ST3Gal1 expression was found to be associated with inflammation of the intestinal mucosa in patients with UC and a mouse model of dextran sulfate sodium-induced colitis.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC12750049:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12750049",
      "text_span_id": "results_2",
      "text": "suppressed expression of ST3Gal1 in the intestinal epithelial cell (IEC) monolayer enhanced the functionality of the intestinal barrier, whereas its overexpression caused intestinal barrier function deterioration.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC12750049:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12750049",
      "text_span_id": "results_3",
      "text": "ST3Gal1 expression in the IEC monolayer altered the expression of intestinal mucus barrier-associated mucin 2 (MUC2) and trefoil factor 3 (TFF3), goblet cell differentiation-associated homeobox protein CDX-2 (CDX2), inflammation-associated phosphorylated (p)-STAT3, and the inflammatory mediators IL-1\u03b2, IL-6 and IL-8.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
