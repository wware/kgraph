    {
      "id": "Paper:PMC12757875",
      "class": "Paper",
      "name": "The DDR-immune fitness score: a biomarker for guiding parp and immunotherapy synergy in extensive-stage small cell lung cancer",
      "synonyms": [],
      "symbol": null,
      "brand_names": [],
      "source": "extracted",
      "canonical_id": "PMC12757875",
