  "evidence_entities": [
    {
      "id": "extracted_paper_1:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper_1",
      "text_span_id": "background_1",
      "text": "Despite the integration of PD-L1 inhibitors with chemotherapy, extensive-stage small-cell lung cancer (ES-SCLC) continues to portend a dismal prognosis, with a 5-year survival rate below 10%.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": "computational analysis",
      "source": "extracted"
    },
    {
      "id": "extracted_paper_1:background:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper_1",
      "text_span_id": "background_2",
      "text": "The score, constructed using elastic-net regression, incorporates homologous recombination deficiency (HRD), tumor mutational burden (TMB), and STING pathway activity.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": "computational analysis",
      "source": "extracted"
    },
    {
      "id": "extracted_paper_1:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper_1",
      "text_span_id": "results_1",
      "text": "DDR-IF-high tumors were characterized by a distinct biological profile, including (i) transcriptional exhaustion of the cGAS-STING innate immune pathway (p < 0.001), (ii) significantly reduced CD8+ T cell infiltration (2.3-fold fewer, p = 0.004), and (iii) a superior pooled objective response rate to PARP-ICB combinations (42% vs 18%; risk ratio 2.3, 95% CI 1.3-4.2; p = 0.003).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": "computational analysis",
      "source": "extracted"
    },
    {
      "id": "extracted_paper_1:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper_1",
      "text_span_id": "methods_1",
      "text": "The final DDR-IF score was defined using standardized coefficients: DDR-IF = 0.4 \u00d7 (HRD score) + 0.35 \u00d7 log10(TMB + 1) + 0.25 \u00d7 (STING activation score), where all predictors were z-score normalized prior to model fitting.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": "computational analysis",
      "source": "extracted"
    },
    {
      "id": "extracted_paper_1:section4:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper_1",
      "text_span_id": "section4_1",
      "text": "A meta-analysis of six trials (2020\u20132024) confirmed that DDR-IF-high tumors (e.g., ATM/BRCA1/2-altered) show a 2.3-fold higher ORR to PARP-ICB versus DDR-IF-low (42% vs. 18%, p=0.003).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": "computational analysis",
      "source": "extracted"
    },
    {
      "id": "extracted_paper_1:section4:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper_1",
      "text_span_id": "section4_2",
      "text": "the DDR-IF score demonstrated superior predictive power for PARP-ICB response (AUROC = 0.81) compared to SLFN11 expression alone (AUROC = 0.64), ATM mutation status (AUROC = 0.59), or a simple TMB-PD-L1 composite model (AUROC = 0.72).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": "computational analysis",
      "source": "extracted"
    }
  ],
