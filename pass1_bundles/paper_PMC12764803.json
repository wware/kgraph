  "evidence_entities": [
    {
      "id": "PMC12764803:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12764803",
      "text_span_id": "background_1",
      "text": "HRD subtyping identified distinct genomic, pathological, and immunological features. HRD-High tumours were associated with advanced FIGO stages, TP53 mutations, higher chromosomal instability, and elevated CD8\u207aPD-1\u207a T-cell infiltration.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12764803:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12764803",
      "text_span_id": "results_1",
      "text": "HRD subtyping independently predicted disease-free survival and showed superior prognostic accuracy (C-index = 0.857) compared to TCGA subtyping (C-index = 0.751).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12764803:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12764803",
      "text_span_id": "results_2",
      "text": "Compared to the other two groups, the HRD-high group exhibited higher mutation frequencies in TP53, RAD51, and SPOP, but fewer mutations in PTEN, ARID1A, PIK3R1, CTNNB1, and CTCF.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12764803:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12764803",
      "text_span_id": "results_3",
      "text": "The HRD score was strongly positively correlated with genomic instability markers, such as SCIN (R = 0.93, p < 0.01) and aneuploidy score (R = 0.83, p < 0.001).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12764803:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12764803",
      "text_span_id": "results_4",
      "text": "HRD-High patients exhibited significantly elevated numbers of CD3+PD-1+ T cells and CD8+PD-1+ T cells in their tumour-immune microenvironment compared to HRD-Middle and HRD-Low groups.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    }
  ],
