  "evidence_entities": [
    {
      "id": "paper_id:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "abstract_1",
      "text": "BRD7 has been confirmed to be lowly expressed in nasopharyngeal carcinoma (NPC) tissues and exerts tumour suppressive roles",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro_in_vivo",
      "source": "extracted"
    },
    {
      "id": "paper_id:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "abstract_2",
      "text": "There was hypermethylation modification in BRD7 promoter, which was negatively correlated with BRD7 expression",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro_in_vivo",
      "source": "extracted"
    },
    {
      "id": "paper_id:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "abstract_3",
      "text": "we constructed a LentiCRISPRv2/dCas9-TET1CD-sgRNAs system targeting specific methylation sites of BRD7 promoter based on five sgRNAs, and confirmed that all five sgRNA-guided CRISPR/dCas9 systems could activate BRD7 and inhibit cell proliferation",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro_in_vivo",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_1",
      "text": "The findings confirmed that the BRD7 expression level in NPC cell lines was lower compared to that in normal NPE cell line NP69",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_2",
      "text": "The results of the MSP confirmed that the BRD7 promoter exhibited hypermethylation of the CpG island in NPC cell lines compared to NPE cell NP69",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_3",
      "text": "the five sgRNAs-guided dCas9-TET1CD system could promote BRD7 expression at mRNA and protein levels in NPC cells to varying degrees when compared to the control group, of which the sgRNA2 and sgRNA5 present the most pronounced effects",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_4",
      "text": "stable expression of dCas9-TET1CD-sgRNA2 and dCas9-TET1CD-sgRNA5 markedly suppressed tumour growth in vivo when compared to the control group",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vivo",
      "source": "extracted"
    }
