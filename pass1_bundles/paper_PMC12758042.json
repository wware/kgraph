      "text_span_id": "surgery_1",
      "text": "Risk-reducing surgeries, such as bilateral salpingo-oophorectomy (BSO) and mastectomy, significantly lower the risk of breast and ovarian cancer",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
