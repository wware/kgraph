  "evidence_entities": [
    {
      "id": "paper_id:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "intro_1",
      "text": "AURKA, which phosphorylates multiple kinases and phosphatases, influences diverse cellular processes including cell cycle progression, centrosome regulation, bipolar spindle formation, and chromosome segregation",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "intro_2",
      "text": "Overexpression of AURKA enables cells to bypass the G2 DNA-damage checkpoint, resulting in centrosome amplification and genomic instability features commonly observed across multiple cancer types",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "intro_3",
      "text": "Overexpression of AURKA has been shown to destabilize p53 through Ser315 phosphorylation, leading to loss of function, centrosome amplification, chromosomal instability, and oncogenic transformation",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:introduction:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "intro_4",
      "text": "AURKA directly phosphorylates the Thr210 residue within the PLK1 kinase domain, initiating mitotic progression",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_1",
      "text": "There was no increase in AURKA gene copy number among the groups (2\u2212\u2206\u2206Ct < 2)",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_2",
      "text": "AURKA level was significantly increased in both test groups (p < 0.001)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_3",
      "text": "Phospho-P53Ser315 levels were significantly higher in both HBV-HCC and Cr-HCC groups compared to the control group (p = 0.002 and p < 0.001, respectively)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_4",
      "text": "For phospho-PLK1Thr210, Cr-HCC cases showed statistically higher expression compared to both the control group and HBV-HCC cases (p = 0.001)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
