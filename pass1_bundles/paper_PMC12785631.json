  "evidence_entities": [
    {
      "id": "PMC12785631:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "results_1",
      "text": "AURKA level was significantly increased in both test groups (p < 0.001). At the protein level, AURKA was significantly higher in both cancer groups compared to the control group (p < 0.001).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12785631:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "results_2",
      "text": "Phospho-P53Ser315 levels were significantly higher in both HBV-HCC and Cr-HCC groups compared to the control group (p = 0.002 and p < 0.001, respectively). Cr-HCC cases also showed significantly higher levels compared to HBV-HCC (p = 0.025).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12785631:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "results_3",
      "text": "For phospho-PLK1Thr210, Cr-HCC cases showed statistically higher expression compared to both the control group and HBV-HCC cases (p = 0.001).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12785631:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "introduction_1",
      "text": "AURKA, which phosphorylates multiple kinases and phosphatases, influences diverse cellular processes including cell cycle progression, centrosome regulation, bipolar spindle formation, and chromosome segregation.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12785631:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "introduction_2",
      "text": "AURKA directly phosphorylates the Thr210 residue within the PLK1 kinase domain, initiating mitotic progression.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12785631:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "introduction_3",
      "text": "Overexpression of AURKA has been shown to destabilize p53 through Ser315 phosphorylation, leading to loss of function, centrosome amplification, chromosomal instability, and oncogenic transformation.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12785631:introduction:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12785631",
      "text_span_id": "introduction_4",
      "text": "In HBV-related HCC, the hepatitis B viral protein HBx interacts with and binds to p53, thereby suppressing key tumor-suppressive mechanisms.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "molecular and immunohistochemical study",
      "eco_type": null,
      "source": "extracted"
    }
