  "evidence_entities": [
    {
      "id": "extracted:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "intro_1",
      "text": "Rates of recurrence and/or persistence of Cushing's disease after surgical treatment are high. Recently, advances in molecular insights and a better understanding of pathophysiology have enabled the development of potential therapeutic targets that could control adrenocorticotropic hormone (ACTH) and cortisol secretion or even reduce tumour cell proliferation.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "intro_2",
      "text": "At the pituitary level, pasireotide is an approved somatostatin receptor ligand, and compounds targeting cell cycle regulation, cell signalling and epigenetics are now under investigation.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "intro_3",
      "text": "Levoketoconazole and osilodrostat are novel steroid inhibitors, and relacorilant overcomes the adverse effects of mifepristone.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "methods_1",
      "text": "Cushing's disease (CD) is caused by an adrenocorticotropic hormone (ACTH)-secreting pituitary adenoma, or rarely carcinoma, and is considered a highly morbid endocrine disorder with few medical options.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:methods:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "methods_2",
      "text": "Although transsphenoidal pituitary surgery (TSS) is the mainstay of treatment for this disease, up to one-third of the patients eventually relapse and are required to be treated with a variety of drugs, as none can achieve optimal disease control.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "results_1",
      "text": "Pasireotide is a novel somatostatin analogue targeting four out of five SSTR subtypes, with the highest affinity for SSTR5.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "results_2",
      "text": "The first randomized phase III clinical trial involving 162 patients with CD treated with subcutaneous pasireotide showed urine-free cortisol (UFC) normalization at month 6 in 15\u201326% of the patients without uptitration.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Clinical Trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "results_3",
      "text": "Despite the benefits of pasireotide, about two-thirds of the patients developed hyperglycaemia-related adverse events, requiring additional antidiabetic treatment.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Clinical Trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "results_4",
      "text": "Starting at a dose of 300 mg/day and titrated up to 1,200 mg/day, levoketoconazole normalized mean urinary free cortisol (mUFC) levels in more than 50% of the patients.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Clinical Trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "results_5",
      "text": "At the end of the core study (at week 48), osilodrostat resulted in a complete response in 66% and a partial response (\u226550% reduction of UFC) in 9% of the enrolled patients, respectively.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Clinical Trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:results:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "results_6",
      "text": "A phase II study over 20 weeks showed that, after dose stabilization, 42% and 15% of the patients coming from the low-dose group (200 mg/day) demonstrated a blood pressure reduction of \u22655 mmHg and a glycaemic reduction, respectively, whereas in the high-dose group (400 mg/day), an improvement in hypertension and glucose metabolism was achieved in 64% and 50%, respectively.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Clinical Trial",
      "eco_type": null,
      "source": "extracted"
    }
  ],
