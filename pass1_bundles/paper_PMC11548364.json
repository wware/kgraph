  "evidence_entities": [
    {
      "id": "PMC11548364:abstract:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "abstract_0",
      "text": "Rates of recurrence and/or persistence of Cushing's disease after surgical treatment are high.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "abstract_1",
      "text": "pasireotide is an approved somatostatin receptor ligand",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_2",
      "text": "Cushing's disease (CD) is caused by an adrenocorticotropic hormone (ACTH)-secreting pituitary adenoma, or rarely carcinoma",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_3",
      "text": "transsphenoidal pituitary surgery (TSS) is the mainstay of treatment for this disease",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_4",
      "text": "hepatotoxicity is a major issue in treatment with ketoconazole, while hirsutism and hypertension are associated with metyrapone",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_5",
      "text": "Pasireotide is a novel somatostatin analogue targeting four out of five SSTR subtypes, with the highest affinity for SSTR5",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_6",
      "text": "about two-thirds of the patients developed hyperglycaemia-related adverse events, requiring additional antidiabetic treatment",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_7",
      "text": "36\u201362% of corticotroph adenomas show gain-of-function mutations in the gene encoding for USP8",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11548364:body:8:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11548364",
      "text_span_id": "body_8",
      "text": "Osilodrostat is a potent inhibitor of 11\u03b2-hydroxylase and aldosterone synthase",
      "confidence": 0.95,
      "extraction_method": "llm",
