  "evidence_entities": [
    {
      "id": "PMC_unknown:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_unknown",
      "text_span_id": "methods_1",
      "text": "This cross-sectional study was conducted between June and July 2023 at Zhejiang Chinese Medical University and Zunyi Medical College, and included medical students from both institutions.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_unknown:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_unknown",
      "text_span_id": "results_1",
      "text": "A total of 520 valid questionnaires were collected, with 304 (58.46%) females and a mean age of 21.07 \u00b1 2.25 years.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_unknown:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_unknown",
      "text_span_id": "results_2",
      "text": "The mean knowledge, attitude, and practice scores were 9.39 \u00b1 3.82 (possible range: 0\u201320), 31.4 \u00b1 4.06 (possible range: 8\u201340), and 25.2 \u00b1 7.04 (possible range: 8\u201340), respectively.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_unknown:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_unknown",
      "text_span_id": "results_3",
      "text": "Structural equation modeling (SEM) indicated that knowledge directly influenced attitude (\u03b2 = 0.140, P = 0.003), attitude directly affected practice (\u03b2 = 0.145, P = 0.002), and knowledge had a substantial and direct impact on practice (\u03b2 = 0.219, P < 0.001).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    }
