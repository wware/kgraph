  "evidence_entities": [
    {
      "id": "PMC_UNKNOWN:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_1",
      "text": "Cushing's disease (CD) is caused by an adrenocorticotropic hormone (ACTH)-producing pituitary adenoma and is the most common cause of endogenous Cushing's syndrome",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_2",
      "text": "The recommended first-line therapy is selective transsphenoidal surgical resection of the ACTH-secreting adenoma",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_3",
      "text": "Medical treatment options include steroidogenesis inhibitors (ketoconazole, metyrapone, osilodrostat, mitotane, etomidate), which block one or more steps in adrenal cortisol synthesis",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_1",
      "text": "Ketoconazole was the most frequently used drug, with a median rate of usage of 26.5% (5-66.7) of those receiving medical therapy",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_2",
      "text": "The median rates of metyrapone and pasireotide use were 17.2% (0\u201350) and 9.3% (0-51.7), respectively",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_3",
      "text": "The overall median control rate of CD patients receiving medical treatment was 75% (10\u2013100)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_4",
      "text": "The median biochemical control rate of ketoconazole provided by 7 centers was 76% (range: 20\u2013100)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "discussion_1",
      "text": "Ketoconazole blocks multiple steroid biosynthesis pathways and has been reported to normalize urinary free cortisol (UFC) levels in 64.7% of patients with CD",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "discussion_2",
      "text": "Metyrapone, an 11\u00df-hydroxylase inhibitor, utilized in 17.2% of patients under medical treatment",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": "audit",
      "source": "extracted"
    },
