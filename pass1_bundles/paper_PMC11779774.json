      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "discussion_2",
      "text": "Metyrapone, an 11\u00df-hydroxylase inhibitor, utilized in 17.2% of patients under medical treatment.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "audit",
      "eco_type": "retrospective_analysis",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:discussion:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "discussion_3",
      "text": "Osilodrostat, oral 11\u00df-hydroxylase and aldosterone synthase inhibitor has a higher potency and a longer half-life than metyrapone and ketoconazole.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "audit",
      "eco_type": "retrospective_analysis",
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:discussion:4:llm",
