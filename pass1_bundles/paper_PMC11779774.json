      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_1",
      "text": "Ketoconazole was the most frequently used drug, with a median rate of usage of 26.5% (5-66.7) of those receiving medical therapy",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
