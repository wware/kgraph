  "evidence_entities": [
    {
      "id": "PMC3578024:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "intro_1",
      "text": "Cross-sensitization in the pelvis may contribute to etiology of functional pelvic pain disorders such as interstitial cystitis/bladder pain syndrome (IC/BPS).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3578024:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "intro_2",
      "text": "Increasing evidence suggests the involvement of transient receptor potential vanilloid 1 (TRPV1) receptors in the development of neurogenic inflammation in the pelvis and pelvic organ cross-sensitization.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3578024:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "results_1",
      "text": "The duration of excitatory responses to noxious UBD during acute colonic inflammation (3 days post-TNBS) was significantly shortened in the group with RTX pretreatment (25.37\u00b1.5 s, n=49) when compared to the control group (35.1\u00b14.2 s, n=43, p\u22640.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3578024:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "results_2",
      "text": "The duration of long-lasting excitatory responses, but not short-lasting responses of bladder spinal neurons during acute colitis was significantly reduced by RTX from 52.9\u00b16.6 s (n=21, vehicle group) to 34.4\u00b12.1 s (RTX group, n=21, p\u22640.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3578024:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "results_3",
      "text": "However, activation of TRPV1 receptors in the urinary bladder prior to acute colitis increased the number of bladder neurons receiving input from large somatic fields from 22.7% to 58.2% (p\u22640.01).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3578024:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "results_4",
      "text": "These results provide evidence for a significant decrease in TRPV1 expression after intravesical treatment with RTX in the urothelium and DSM without changes in the distal colon.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3578024:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578024",
      "text_span_id": "results_5",
      "text": "Acute colitis (TNBS, 3 days), however, had no effect on the expression of TRPV1 in the urinary bladder, but increased the level of the protein in the distal colon by 2-fold (Fig. 1C, p\u22640.05).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    }
  ],
