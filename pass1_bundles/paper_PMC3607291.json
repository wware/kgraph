  "evidence_entities": [
    {
      "id": "PMC3622825:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3622825",
      "text_span_id": "results_1",
      "text": "The duration of excitatory responses to noxious UBD during acute colonic inflammation (3 days post-TNBS) was significantly shortened in the group with RTX pretreatment (25.37\u00b1.5 s, n=49) when compared to the control group (35.1\u00b14.2 s, n=43, p\u22640.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3622825:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3622825",
      "text_span_id": "results_2",
      "text": "The duration of long-lasting excitatory responses, but not short-lasting responses of bladder spinal neurons during acute colitis was significantly reduced by RTX from 52.9\u00b16.6 s (n=21, vehicle group) to 34.4\u00b12.1 s (RTX group, n=21, p\u22640.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3622825:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3622825",
      "text_span_id": "results_3",
      "text": "However, activation of TRPV1 receptors in the urinary bladder prior to acute colitis increased the number of bladder neurons receiving input from large somatic fields from 22.7% to 58.2% (p\u22640.01).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3622825:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3622825",
      "text_span_id": "results_4",
      "text": "The development of acute colitis at day 3 post-TNBS treatment was also confirmed by a 4.5-fold increase in MPO concentration in the distal colon without significant changes in the groups with vehicle (control) and intravesical RTX.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3622825:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3622825",
      "text_span_id": "results_5",
      "text": "These results provide evidence for a significant decrease in TRPV1 expression after intravesical treatment with RTX in the urothelium and DSM without changes in the distal colon.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    }
