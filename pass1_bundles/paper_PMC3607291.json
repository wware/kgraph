  "evidence_entities": [
    {
      "id": "PMC3578000:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578000",
      "text_span_id": "abstract_1",
      "text": "Cross-sensitization in the pelvis may contribute to etiology of functional pelvic pain disorders such as interstitial cystitis/bladder pain syndrome (IC/BPS).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal model",
      "source": "extracted"
    },
    {
      "id": "PMC3578000:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578000",
      "text_span_id": "abstract_2",
      "text": "Increasing evidence suggests the involvement of transient receptor potential vanilloid 1 (TRPV1) receptors in the development of neurogenic inflammation in the pelvis and pelvic organ cross-sensitization.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal model",
      "source": "extracted"
    },
    {
      "id": "PMC3578000:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578000",
      "text_span_id": "abstract_3",
      "text": "The duration of excitatory responses to noxious UBD during acute colonic inflammation (3 days post-TNBS) was significantly shortened in the group with RTX pretreatment (25.37\u00b1.5 s, n=49) when compared to the control group (35.1\u00b14.2 s, n=43, p\u22640.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal model",
      "source": "extracted"
    },
    {
      "id": "PMC3578000:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578000",
      "text_span_id": "results_1",
      "text": "A significant decrease in TRPV1 expression after intravesical treatment with RTX in the urothelium and DSM without changes in the distal colon.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal model",
      "source": "extracted"
    },
    {
      "id": "PMC3578000:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578000",
      "text_span_id": "results_2",
      "text": "Acute colitis (TNBS, 3 days), however, had no effect on the expression of TRPV1 in the urinary bladder, but increased the level of the protein in the distal colon by 2-fold.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal model",
      "source": "extracted"
    },
    {
      "id": "PMC3578000:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3578000",
      "text_span_id": "discussion_1",
      "text": "TRPV1 receptors in the urinary bladder do not contribute to the responses of bladder spinal neurons to mechanical stimulation (UBD) during colon\u2013bladder cross-talk, rather, they are involved in inflammation induced hyperexcitability of these neurons.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal model",
      "source": "extracted"
    }
  ],
