  "evidence_entities": [
    {
      "id": "editorial:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "Endogenous Cushing's syndrome results in significant multisystemic morbidity and elevated mortality if left untreated",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "The study by Pekul et al. emphasized the relevance of USP and TP53 mutations in pituitary tumors for prognostic guidance by comparing corticotroph tumors causing Cushing's disease (CD) with their silent counterparts",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "A meta-analysis by Giampetro et al. evaluated the use of desmopressin for diagnostic purposes, a review that is particularly relevant given the limited availability of CRH in many countries",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "The article discussed the strengths and limitations of interpreting the 10mcg desmopressin test in differentiating between ACTH-dependent Cushing's syndrome and non-neoplastic hypercortisolism",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "A retrospective cohort study presented by Skrebsky De Almeida et al. investigated the role of desmopressin during Bilateral Inferior Petrosal Sinus Sampling (BIPSS), presenting sensitivity and specificity values of the central-to-peripheral ratio before and after stimulation",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "Wright et al. provided a review of emerging diagnostic methods, including advanced functional imaging and measurement of hair cortisol and cortisone, addressing the limitations of current tests while highlighting the advantages of novel approaches",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "The impact of hypercortisolism on the gut microbiota was explored in a case-control study by Valassi et al. that offered insights into the ongoing cardiometabolic consequences of Cushing's syndrome",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "Feelders et al. shared the results of the extension of a multicenter Phase II study in which patients were initially treated with pasireotide which was subsequently combined with cabergoline if cortisol levels remained elevated",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "editorial:contributions:8:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "editorial",
      "text_span_id": null,
      "text": "The study demonstrated that this combination of pituitary-targeted therapies can yield sustained long-term efficacy in selected patients",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Editorial",
      "eco_type": null,
      "source": "extracted"
    }
