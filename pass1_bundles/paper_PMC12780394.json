      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "disc_3",
      "text": "The PD-L1 protein plays a central role in the antitumor immune response",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "bibliometric analysis",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:discussion:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "disc_4",
      "text": "miR-182-5p's oncogenic function was first identified in melanoma, where the miRNA promotes tumor migration and invasion by inhibiting the activity of the forkhead box O3 (FOXO3) transcription factor",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "bibliometric analysis",
      "eco_type": null,
