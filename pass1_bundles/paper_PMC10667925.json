  "evidence_entities": [
    {
      "id": "paper_1:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "intro_1",
      "text": "The adrenal glands are small endocrine glands located on top of each kidney, producing hormones regulating important functions in our body like metabolism and stress.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "intro_2",
      "text": "There are several underlying causes for adrenal insufficiency, where an autoimmune attack by the immune system is the most common cause.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section1:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section1_1",
      "text": "The adrenal cortex is responsible for producing glucocorticoids, mineralocorticoids, and adrenal androgens whereas the medulla produces adrenaline and noradrenaline, also referred to as catecholamines",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section1:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section1_2",
      "text": "Glucocorticoids, primarily cortisol, also known as the stress hormone, have numerous effects on metabolism.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section1:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section1_3",
      "text": "Primary AI (PAI), also known as Addison's disease, is a rare disease with a prevalence of approximately 100 per million in Europe",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section2:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section2_1",
      "text": "Morning cortisol concentration <140 nmol/L and an ACTH concentration twice the upper reference limit verifies a PAI diagnosis",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section2:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section2_2",
      "text": "In Western countries, where other than autoimmune causes of PAI are uncommon, serum 21-hydroxylase antibodies should be assessed.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section2:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section2_3",
      "text": "The standard medication of glucocorticoid treatment for patients with AI (primary and secondary) is hydrocortisone or cortisone acetate",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section3:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section3_1",
      "text": "A number of genes are known to confer early onset adrenal disease in monogenic inheritance patterns, including genetic defects in enzymes of adrenal steroidogenesis (e.g., CYP21A1 and CYP11A1)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section4:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section4_1",
      "text": "The autoantibodies targeting 21-OH was first described in 1992 by Winqvist et al., identified as a major autoantigen in autoimmune PAI",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section4:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section4_2",
      "text": "These antibodies have since then been shown to be highly specific for autoimmune PAI in several patient cohorts, and found present in 80\u201390% of patients with PAI",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section5:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section5_1",
      "text": "Two immunodominant peptides have been found to be recognized by CD8+ T cells.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:section6:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "section6_1",
      "text": "For T1D, the FDA recently approved teplizumab as the first disease-modifying therapy in type 1 diabetes.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    }
  ],
