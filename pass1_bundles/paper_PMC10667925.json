  "evidence_entities": [
    {
      "id": "PMC_extracted:introduction:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "intro_0",
      "text": "Autoimmune primary adrenal insufficiency is usually a polygenic disease where our information recently has increased due to genome association studies.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section1:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section1_1",
      "text": "The most common cause of primary adrenal insufficiency is autoimmunity; this type is often called Autoimmune Addison's Disease, or simply autoimmune PAI.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section2:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section2_2",
      "text": "Morning cortisol concentration <140 nmol/L and an ACTH concentration twice the upper reference limit verifies a PAI diagnosis.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section2:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section2_3",
      "text": "The principle of adrenal insufficiency treatment is replacement of deficient hormones. In PAI, patients need replacement of both glucocorticoids and mineralocorticoids.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section3:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section3_4",
      "text": "We recently performed the world's first GWAS on autoimmune PAI including only ~1200 patients, but which succeeded to elucidate nine genetic regions with quite remarkable risk potential for PAI.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section4:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section4_5",
      "text": "The autoantibodies targeting 21-OH was first described in 1992 by Winqvist et al., identified as a major autoantigen in autoimmune PAI. These antibodies have since then been shown to be highly specific for autoimmune PAI in several patient cohorts.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section5:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section5_6",
      "text": "Two immunodominant peptides have been found to be recognized by CD8+ T cells. They demonstrated that T cells from PAI individuals, unlike healthy controls, responded to the pool of 21-OH peptides.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:section6:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "section6_7",
      "text": "For T1D, the FDA recently approved teplizumab as the first disease-modifying therapy in type 1 diabetes. Teplizumab is a humanized anti-CD3 monoclonal antibody found to delay the onset of stage 3 type 1 diabetes.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    }
