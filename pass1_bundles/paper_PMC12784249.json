  "evidence_entities": [
    {
      "id": "PMC11729066:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729066",
      "text_span_id": "abstract_1",
      "text": "The integration of genome-scale metabolic and regulatory networks has received significant interest in cancer systems biology. However, the identification of lethal genetic interventions in these integrated models remains challenging due to the combinatorial explosion of potential solutions.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "computational_study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11729066:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729066",
      "text_span_id": "introduction_2",
      "text": "This strategy has driven the development of sophisticated targeted therapies in cancer, such as PARP inhibitors for patients with BRCA1- or BRCA2-mutated breast cancer",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "computational_study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11729066:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729066",
      "text_span_id": "results_3",
      "text": "Among different candidates, we identified the essentiality of EZH2 specifically in hematological cancer cell lines in all iMR models build on TRRUST. Interestingly, this gene has been previously identified as a drug target of different hematological tumors.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "computational_study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11729066:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729066",
      "text_span_id": "results_4",
      "text": "Here, the lethality of EZH2 inhibition is mediated by the following gMIS: {EZH2\u2212, JUN\u2212, RELA+}, hypothesizing a higher impact in cellular proliferation when the expression of JUN is down-regulated and RELA is up-regulated.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "computational_study",
      "eco_type": null,
      "source": "extracted"
    }
  ],
