  "evidence_entities": [
    {
      "id": "paper_id:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_1",
      "text": "The dual DNA\u2013RNA test identified significantly more fusion genes (20.3% vs. 7.4%, p < 0.001) and therapeutically targetable kinase fusions (3.5% vs. 1.2%, p = 0.019) than the DNA\u2010only test.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Retrospective cohort study",
      "eco_type": "Real-world evidence study",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_2",
      "text": "Among patients with translocation\u2010related sarcomas, histology\u2010specific fusion genes were identified in 77.5% using the dual panel, compared to 40.0% with the DNA\u2010only panel (p < 0.001).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Retrospective cohort study",
      "eco_type": "Real-world evidence study",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_3",
      "text": "In non\u2010gastrointestinal stromal tumor sarcomas, the dual test showed a trend toward higher rates of genotype\u2010matched therapy (4.3% vs. 2.6%, p = 0.25) and a significantly higher rate of molecular targeted therapy (4.3% vs. 1.5%, p = 0.03).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Retrospective cohort study",
      "eco_type": "Real-world evidence study",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_4",
      "text": "Additionally, 5.7% of patients had pathogenic germline variants identified through tumor\u2013normal matched analysis.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Retrospective cohort study",
      "eco_type": "Real-world evidence study",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_5",
      "text": "Genotype\u2010matched therapy was administered to 22 patients (3.2%), including 12 of 464 patients (2.6%) in the F1CDx group and 10 of 231 patients (4.3%) in the GenMineTOP group (p = 0.25).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Retrospective cohort study",
      "eco_type": "Real-world evidence study",
      "source": "extracted"
    }
  ],
