  "evidence_entities": [
    {
      "id": "PMC_FERROPTOSIS_2024:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "intro_1",
      "text": "Ferroptosis is an iron-dependent form of programmed cell death that is driven by the accumulation of reactive oxygen species (ROS), leading to the formation of membrane-damaging lipid peroxides",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "intro_2",
      "text": "The manipulation of ferroptosis has become an attractive area of cancer research, as both the promotion and inhibition of this form of cell death have been seen to positively affect cancer outcomes",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:players:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "players_1",
      "text": "Iron in its ferrous state (Fe2+) is required for the Fenton reaction, a chemical process in which ferrous iron ions are used in the decomposition of hydrogen peroxide (H2O2) to create reactive hydroxyl radicals",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:players:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "players_2",
      "text": "The xCT system is composed of two transmembrane proteins, SLC7A11 and SLC3A2, which create a cystine/glutamate antiporter",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:suppression:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "suppression_1",
      "text": "TP53 is the most frequently mutated tumor-suppressor gene and can play an important role in the promotion of ferroptosis in cancer",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:therapeutics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "therapeutics_1",
      "text": "Erastin acts through the inhibition of the xCT antiporter composed of both SLC7A11 and SLC3A2. Inhibition of this antiporter leads to decreased intracellular cystine uptake and subsequent depletion of GSH",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:therapeutics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "therapeutics_2",
      "text": "RSL3 is another induction molecule that directly inhibits GPX4 by bypassing the need for GSH depletion",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:immune:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "immune_1",
      "text": "Dendritic cells failed to effectively present tumor antigens as they undergo ferroptosis, resulting in weakened CD8+ T cell responses",
      "confidence": 0.9,
      "extraction_method": "llm",
