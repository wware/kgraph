  "evidence_entities": [
    {
      "id": "paper:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Ferroptosis is an iron-dependent form of programmed cell death that is driven by the accumulation of reactive oxygen species (ROS), leading to the formation of membrane-damaging lipid peroxides",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "The manipulation of ferroptosis has become an attractive area of cancer research, as both the promotion and inhibition of this form of cell death have been seen to positively affect cancer outcomes",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:players:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Iron in its ferrous state (Fe2+) is required for the Fenton reaction, a chemical process in which ferrous iron ions are used in the decomposition of hydrogen peroxide (H2O2) to create reactive hydroxyl radicals",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:players:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "ACSL4 allows for the activation of PUFAs, making them much more susceptible to peroxidation, and LPCAT3 allows for the incorporation of PUFAs into phospholipids, which also enhances their susceptibility to peroxidation",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:players:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "The xCT system is composed of two transmembrane proteins, SLC7A11 and SLC3A2, which create a cystine/glutamate antiporter",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:suppression:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "p53 downregulates SLC7A11 expression, a key component of the xCT system, through its direct binding to the promoter of SLC7A11",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:suppression:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "BAP1 can remove the H2A ubiquitination on the SLC7A11 promoter, therefore decreasing its transcription and reducing intracellular cystine uptake and promoting ferroptosis",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:therapeutics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Erastin acts through the inhibition of the xCT antiporter composed of both SLC7A11 and SLC3A2. Inhibition of this antiporter leads to decreased intracellular cystine uptake and subsequent depletion of GSH",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:therapeutics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "RSL3 is another induction molecule that directly inhibits GPX4 by bypassing the need for GSH depletion",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:therapeutics:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "sorafenib enhances ferroptosis through the inhibition of SLC7A11 and subsequent decrease in cystine uptake",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:immune:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Dendritic cells failed to effectively present tumor antigens as they undergo ferroptosis, resulting in weakened CD8+ T cell responses",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:immune:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "IFN-\u03b3, which is secreted by CD8+ T cells, can downregulate the expression of the Xc\u2212 system in tumor cells, making them more susceptible to ferroptosis",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    }
