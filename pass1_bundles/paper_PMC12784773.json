  "evidence_entities": [
    {
      "id": "PMC_PLACEHOLDER:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "intro_ferroptosis_def",
      "text": "Ferroptosis is an iron-dependent form of programmed cell death that is driven by the accumulation of reactive oxygen species (ROS), leading to the formation of membrane-damaging lipid peroxides",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:players:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "fenton_reaction",
      "text": "Iron in its ferrous state (Fe2+) is required for the Fenton reaction, a chemical process in which ferrous iron ions are used in the decomposition of hydrogen peroxide (H2O2) to create reactive hydroxyl radicals",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:players:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "gpx4_function",
      "text": "GSH is oxidized via glutathione peroxidase 4 (GPX4) to form oxidized GSSG in order to neutralize harmful lipid peroxides, and thus protect the cell from membrane damage and cell death",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:suppression:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "p53_slc7a11",
      "text": "p53 is crucial for restricting tumor cell growth and, in terms of ferroptosis, downregulates SLC7A11 expression, a key component of the xCT system",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:therapeutics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "erastin_mechanism",
      "text": "Erastin acts through the inhibition of the xCT antiporter (or Xc\u2212 system) composed of both SLC7A11 and SLC3A2. Inhibition of this antiporter leads to decreased intracellular cystine uptake and subsequent depletion of GSH",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:therapeutics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "rsl3_mechanism",
      "text": "RSL3 is another induction molecule that directly inhibits GPX4 by bypassing the need for GSH depletion",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:therapeutics:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "sorafenib_mechanism",
      "text": "sorafenib enhances ferroptosis through the inhibition of SLC7A11 and subsequent decrease in cystine uptake",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_PLACEHOLDER:immune:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_PLACEHOLDER",
      "text_span_id": "ifn_gamma_ferroptosis",
      "text": "IFN-\u03b3, which is secreted by CD8+ T cells, can downregulate the expression of the Xc\u2212 system (which includes SLC7A11) in tumor cells, making them more susceptible to ferroptosis",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    }
  ],
