      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "introduction_3",
      "text": "brain regions such as the prefrontal cortex and amygdala are also impacted, potentially causing attentional deficits, impaired executive function, and emotional regulation disturbances.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
