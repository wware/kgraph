  "evidence_entities": [
    {
      "id": "PMC12035109:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "background_1",
      "text": "Prolonged high-concentration cortisol exposure may impair cognitive function, but its mechanisms and risk factors remain unclear in humans.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12035109:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "results_1",
      "text": "Cortisol AM/PM ratio, 8 a.m. cortisol concentration, body mass index, and fasting plasma glucose were significant risk factors for cognitive impairment.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12035109:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "introduction_2",
      "text": "High cortisol exerts its effects through glucocorticoid receptors and mineralocorticoid receptors in the hippocampus, mediating neurophysiological responses.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12035109:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "introduction_3",
      "text": "Prolonged activation may lead to neuronal damage, reduced neuroplasticity, and cognitive impairment.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12035109:introduction:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "introduction_4",
      "text": "Cushing's disease is an endocrine disorder caused by excess adrenocorticotropic hormone (ACTH) secretion by anterior pituitary adenomas, leading to abnormally elevated cortisol levels.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12035109:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "discussion_1",
      "text": "Increased BMI was identified as an independent risk factor for cognitive impairment, likely due to chronic inflammation and oxidative stress caused by metabolic disorders.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12035109:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12035109",
      "text_span_id": "discussion_2",
      "text": "High blood glucose was another critical risk factor, potentially affecting cognitive function through various mechanisms: prolonged hyperglycemia can lead to cerebrovascular damage and impaired blood supply to the brain.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    }
  ],
