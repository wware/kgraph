  "evidence_entities": [
    {
      "id": "PMC12788344:case_overview:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12788344",
      "text_span_id": "case_overview_1",
      "text": "A 36\u2010year\u2010old, nulligravid woman with a history of controlled eosinophilic esophagitis, asthma, and dense fibrocystic breasts was referred to the Breast Health Center after abnormal screening mammography.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12788344:case_overview:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12788344",
      "text_span_id": "case_overview_2",
      "text": "She completed a comprehensive 76\u2010gene germline genetic test, which revealed tumor protein p53 (TP53) likely pathogenic variant (LPV; c.716A>G; p.N239S).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12788344:case_overview:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12788344",
      "text_span_id": "case_overview_3",
      "text": "When TP53 PVs/LPVs are identified in a comprehensive germline panel, this raises concern for Li\u2013Fraumeni syndrome (LFS).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12788344:pathology:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12788344",
      "text_span_id": "pathology_1",
      "text": "Initial biopsies demonstrated bilateral high\u2010grade DCIS, both of which were ER\u2010positive (90%\u201395%; strong).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "==CURRENT_PAPER__genetics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12788344",
      "text_span_id": "genetics_1",
      "text": "The same specific TP53 LPV (c.716A>G [p.N239S]) was detected in all three tumors.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12788344:genetics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12788344",
      "text_span_id": "genetics_2",
      "text": "The evidence of the somatic molecular testing and the embryos is consistent with mosaicism in our patient and is diagnostic for LFS.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
