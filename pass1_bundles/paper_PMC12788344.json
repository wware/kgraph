  "evidence_entities": [
    {
      "id": "PMC_UNKNOWN:case_overview:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "case_overview_1",
      "text": "A 36\u2010year\u2010old, nulligravid woman with a history of controlled eosinophilic esophagitis, asthma, and dense fibrocystic breasts was referred to the Breast Health Center after abnormal screening mammography.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:case_overview:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "case_overview_2",
      "text": "She completed a comprehensive 76\u2010gene germline genetic test, which revealed tumor protein p53 (TP53) likely pathogenic variant (LPV; c.716A>G; p.N239S).",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:genetics:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "genetics_3",
      "text": "It has been determined that clonal hematopoiesis is causative of a blood/saliva next\u2010generation sequencing result in 25%\u201338.8% of cases.",
      "confidence": 0.92,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:genetics:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "genetics_4",
      "text": "The same specific TP53 LPV (c.716A>G [p.N239S]) was detected in all three tumors.",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:genetics:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "genetics_5",
      "text": "In our patient, the VAF for the TP53 c.716A>G in each lesion was as follows: left breast DCIS, 2.4%; right breast DCIS, 33.9%; and left phyllodes tumor, 60.8%.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:surgery:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "surgery_6",
      "text": "The breast cancer risk for women with LFS/germline TP53 LPVs/PVs is 80%\u201390%, with most breast cancers occurring at a younger age.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:radiation_oncology:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "radiation_oncology_7",
      "text": "It has been demonstrated that patients with LFS who receive radiation therapy have an increased risk of radiation\u2010related malignancies within irradiated areas. The reported risk of developing radiation\u2010induced malignancy ranges from 15% to 35% in the modern literature.",
      "confidence": 0.93,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    }
