  "evidence_entities": [
    {
      "id": "PMC_UNKNOWN:case_overview:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "case_overview_1",
      "text": "She completed a comprehensive 76-gene germline genetic test, which revealed tumor protein p53 (TP53) likely pathogenic variant (LPV; c.716A>G; p.N239S).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:case_overview:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "case_overview_2",
      "text": "When TP53 PVs/LPVs are identified in a comprehensive germline panel, this raises concern for Li\u2013Fraumeni syndrome (LFS).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:genetics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "genetics_1",
      "text": "LFS is a hereditary cancer syndrome that is associated with increased risk for multiple cancers, including, but not limited to, breast cancer, sarcoma, central nervous system tumors, and adrenocortical carcinoma.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:genetics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "genetics_2",
      "text": "It has been determined that clonal hematopoiesis is causative of a blood/saliva next-generation sequencing result in 25%\u201338.8% of cases.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:genetics:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "genetics_3",
      "text": "The same specific TP53 LPV (c.716A>G [p.N239S]) was detected in all three tumors.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:surgery:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "surgery_1",
      "text": "The breast cancer risk for women with LFS/germline TP53 LPVs/PVs is 80%\u201390%, with most breast cancers occurring at a younger age.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:radiation_oncology:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "radiation_oncology_1",
      "text": "It has been demonstrated that patients with LFS who receive radiation therapy have an increased risk of radiation-related malignancies within irradiated areas.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
