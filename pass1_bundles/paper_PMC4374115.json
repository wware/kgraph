  "evidence_entities": [
    {
      "id": "PMC_UNKNOWN:introduction:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_0",
      "text": "Cushing's disease is a rare disorder characterized by overproduction of ACTH from a pituitary adenoma leading to hypercortisolemia that in turn leads to increased morbidity and mortality.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_1",
      "text": "Recent evidence suggests that correction of hypercortisolemia may not lead to complete resolution of comorbidities associated with this condition.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_0",
      "text": "increased cardiovascular risk may persist despite long-term remission of hypercortisolemia",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_1",
      "text": "Prior prolonged exposure to glucocorticoids also may have irreversible effects on the central nervous system, leading to persistent cognitive and mood alterations.",
      "confidence": 0.8,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:body:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "body_0",
      "text": "Multiple studies show that the standardized mortality ratio (SMR) is increased in CD (1.7\u20134.8)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:body:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "body_1",
      "text": "Cardiovascular and cerebrovascular events are the most common cause of death in CD",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:body:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "body_2",
      "text": "Hypertension occurs in 55\u201385 % of CD patients",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:body:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "body_3",
      "text": "The prevalence of overt diabetes mellitus is 20\u201347 % and that of impaired glucose tolerance is 21\u201364 % in CD",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
