  "evidence_entities": [
    {
      "id": "PMC_UNKNOWN:introduction:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_0",
      "text": "Cushing's disease is a rare disorder characterized by overproduction of ACTH from a pituitary adenoma leading to hypercortisolemia that in turn leads to increased morbidity and mortality.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_0",
      "text": "Recent evidence suggests that correction of hypercortisolemia may not lead to complete resolution of comorbidities associated with this condition.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_1",
      "text": "In particular, increased cardiovascular risk may persist despite long-term remission of hypercortisolemia.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_2",
      "text": "This may be related to persistence of visceral adiposity, adverse adipokine profile, glucose intolerance, hypertension, dyslipidemia, atherosclerosis and a procoagulant phenotype.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_3",
      "text": "Prior prolonged exposure to glucocorticoids also may have irreversible effects on the central nervous system, leading to persistent cognitive and mood alterations.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:mortality:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "mortality_0",
      "text": "Multiple studies show that the standardized mortality ratio (SMR) is increased in CD (1.7\u20134.8), especially in patients with persistent hypercortisolism (3.7\u20134.2) compared to those in remission (1.8\u20133.17).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:cardiovascular:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "cardiovascular_0",
      "text": "Cardiovascular risk is increased in CD patients even 5 years after remission.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:hypertension:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "hypertension_0",
      "text": "Hypertension occurs in 55\u201385 % of CD patients, but resolves after remission in only 44\u201375 %.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
