  "evidence_entities": [
    {
      "id": "paper_1:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_1",
      "text": "PSMD14 demonstrates elevated mRNA expression across multiple cancer types compared to normal tissues. In lung adenocarcinoma (LUAD), PSMD14 is upregulated not only at the transcriptional level but also at the protein level.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_2",
      "text": "Receiver operating characteristic (ROC) curve analysis yielded an area under the curve (AUC) of 0.898 (95% CI: 0.877\u20130.918), suggesting excellent diagnostic performance.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_3",
      "text": "Kaplan\u2013Meier survival analysis demonstrated that patients with high PSMD14 expression had significantly worse overall survival (OS, p = 0.003), disease-specific survival (DSS, p = 0.001), progression-free interval (PFI, p < 0.001), and disease-free interval (DFI, p < 0.001) compared to those with low expression.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_4",
      "text": "Using co-immunoprecipitation (Co-IP) assays, we confirmed a specific interaction between PSMD14 and HMMR. Subsequent knockdown and overexpression of PSMD14 in LUAD cell lines demonstrated that HMMR expression is positively regulated by PSMD14 at both the mRNA and protein levels.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_5",
      "text": "PSMD14 knockdown markedly enhanced HMMR ubiquitination, whereas its overexpression reduced it. PSMD14 primarily cleaved K63-linked ubiquitin chains from HMMR.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_6",
      "text": "CCK-8 assays revealed that PSMD14 knockdown significantly suppressed proliferation in H1299 and PC9 cells, while its overexpression markedly enhanced proliferation in H1975 cells.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_7",
      "text": "PSMD14-knockdown LUAD cells exhibited impaired migration capability compared to shCtrl-transfected controls, whereas PSMD14 overexpression produced the opposite effect. PSMD14 silencing significantly attenuated both migration and invasion in H1299 and PC9 cells.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:8:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_8",
      "text": "HMMR overexpression substantially rescued the impaired proliferation, migration, and invasion capabilities resulting from PSMD14 knockdown.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:9:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_9",
      "text": "Capzimin treatment effectively suppressed the proliferative and metastatic capacities of LUAD cells. Capzimin notably induced apoptosis and loss of mitochondrial membrane potential.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:10:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_10",
      "text": "PSMD14 knockdown reduced TGF-\u03b2, p-Smad2/3 phosphorylation, and CD44 expression, whereas PSMD14 overexpression increased these markers. PSMD14 knockdown decreased phosphorylation of mTOR, PI3K, and AKT, while its overexpression enhanced their activation.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:11:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1_11",
      "text": "In xenograft models established by injecting PC9 cells, the combination of Capzimin and galunisertib demonstrated synergistic suppression of tumor growth, yielding superior antitumor efficacy compared to either agent alone.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    }
  ],
