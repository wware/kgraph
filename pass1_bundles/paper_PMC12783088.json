  "evidence_entities": [
    {
      "id": "PMC11729015:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729015",
      "text_span_id": "abstract_1",
      "text": "Chimpanzee HCCs exhibited histological and immunohistochemical features similar to human tumors but displayed sharply divergent genomic landscapes. Chimpanzee tumors carried significantly higher coding mutation loads (mean 5632 per sample vs. 96\u2013275 in humans).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729015:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729015",
      "text_span_id": "abstract_2",
      "text": "Non-synonymous TSC2 mutations occurred in 80% of chimpanzees, versus ~7% in human HCC, suggesting a species-specific oncogenic pathway linked to the scirrhous subtype.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729015:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729015",
      "text_span_id": "results_3",
      "text": "TSC2 expression in the chimpanzee samples was mainly cytosolic with high immunostaining in four of the samples, including the metastatic lymph node tissue, and moderate in the remaining two tissue sections.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "immunohistochemistry",
      "source": "extracted"
    },
    {
      "id": "PMC11729015:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729015",
      "text_span_id": "results_4",
      "text": "All chimpanzee HCC tissues (100%) exhibited strong positive staining for VIM, with high signal intensity.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "immunohistochemistry",
      "source": "extracted"
    },
    {
