  "evidence_entities": [
    {
      "id": "PMC11729095:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729095",
      "text_span_id": "results_paragraph_1",
      "text": "Chimpanzee HCCs exhibited histological and immunohistochemical features similar to human tumors but displayed sharply divergent genomic landscapes. Chimpanzee tumors carried significantly higher coding mutation loads (mean 5632 per sample vs. 96\u2013275 in humans).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomic study",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729095:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729095",
      "text_span_id": "results_paragraph_2",
      "text": "Non-synonymous TSC2 mutations occurred in 80% of chimpanzees, versus ~7% in human HCC, suggesting a species-specific oncogenic pathway linked to the scirrhous subtype.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomic study",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729095:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729095",
      "text_span_id": "results_paragraph_3",
      "text": "Despite greater heterogeneity in chimpanzee tumors, humans showed stronger enrichment of non-synonymous single nucleotide variants, implying more intense positive selection.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "comparative genomic study",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729095:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729095",
      "text_span_id": "results_paragraph_4",
      "text": "Shared alterations across species involved canonical drivers such as TP53, CTNNB1, FAT4, and TTN.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomic study",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729095:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729095",
      "text_span_id": "discussion_paragraph_1",
      "text": "TSC2 alterations are present in only 7% of human HCC patients, whereas 80% of chimpanzees with HCC in our study possessed TSC2 mutations.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomic study",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729095:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729095",
      "text_span_id": "discussion_paragraph_2",
      "text": "TSC2 is a tumor suppressor gene that encodes the protein Tuberin complexing with Hamartin, the protein encoded by TSC1, and together they inhibit the mammalian target of rapamycin (mTOR) pathway.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomic study",
      "eco_type": "whole genome sequencing",
      "source": "extracted"
    }
