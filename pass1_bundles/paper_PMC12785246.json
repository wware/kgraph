  "evidence_entities": [
    {
      "id": "PMC_extracted:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_1",
      "text": "The results indicate that the EGF supplement significantly upregulates both the protein and mRNA expression of the Sox11 gene.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_2",
      "text": "Western blot analysis indicates that the SOX11 expression level in both UM2 and UMSCC6 cells significantly increased when N-(3-ethynylphenyl)-6,7-bis(2-methoxyethoxy)-4-quinazolinamine (EMEQA), an EGFR inhibitor, was absent. However, when EMEQA and EGF are both present in the culture medium, the expression of SOX11 was not significantly increased.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_3",
      "text": "Both UM1 and UMSCC5 cells have significantly higher enrichment folds for the DNA fragments of the Sox11 gene promoter in the anti-STAT3-immunoprecipitated or anti-pSTAT3-immunoprecipitated samples than in the IgG-immunoprecipitated samples.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_4",
      "text": "In UM1 and UMSCC5 cells, the siSox11 knockdown significantly promoted E-cadherin gene expression, whereas the gene expression of N-cadherin, vimentin, fibronectin, and EMT-TFs (Twist1, Twist2, Snail, Slug, Zeb1, and Zeb2) was inhibited by siSox11 knockdown.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_5",
      "text": "overexpression of SOX11 promoted the gene expression of N-cadherin, vimentin, fibronectin, and EMT-TFs (Twist1, Twist2, Snail, Slug, Zeb1, and Zeb2) and inhibited the gene expression of E-cadherin in both UM1 and UMSCC5 cells.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_6",
      "text": "an increase in the volume and weight of the xenograft tumors was observed in the SOX11 overexpression (SOX11 OV) group when compared with the control group, whereas the volume and weight of the xenograft tumors were significantly reduced in the SOX11 knockdown (SOX11 KD) group compared to the control group.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vivo",
      "source": "extracted"
    }
  ],
