      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12768212",
      "text_span_id": "main_2",
      "text": "Machine learning (ML) tools such as MARGINAL apply ACMG-AMP criteria to classify BRCA1/2 variants with up to 98% accuracy",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "editorial",
      "eco_type": null,
      "source": "extracted"
    },
