  "evidence_entities": [
    {
      "id": "PMC12768212:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12768212",
      "text_span_id": "abstract_1",
      "text": "The integration of artificial intelligence (AI) into soft tissue sarcoma (STS) diagnostics represents a significant leap toward precision oncology. AI-driven genomic tools, especially in the detection of fusion genes, enhance diagnostic sensitivity, speed, and accuracy, facilitating improved patient stratification and personalized therapy.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12768212:main:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12768212",
      "text_span_id": "main_1",
      "text": "BRCA1/2 mutations account for 10\u201320% of all ovarian cancers, with mutation carriers facing up to a 44% lifetime risk",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "editorial",
      "eco_type": null,
      "source": "extracted"
    },
    {
