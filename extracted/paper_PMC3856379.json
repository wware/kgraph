  "evidence_entities": [
    {
      "id": "PMC3856379:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "Long-term patient adherence to osteoporosis treatment is poor despite proven efficacy.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC3856379:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "In this study, we aimed to assess the impact of active patient training on treatment compliance and persistence in patients with postmenopausal osteoporosis.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC3856379:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "Among the study visits, the most common reason for not receiving treatment regularly was forgetfulness (54.9% for visit 2, 44.3% for visit 3, 51.6% for visit 4, and 43.8% for visit 5)",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC3856379:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "QUALEFFO scores of the patients in visit 1 significantly improved in visit 5 (37.7\u00b125.4 vs. 34.0\u00b114.6, p<0.001)",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC3856379:conclusion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "In conclusion, in addition to active training, passive training provided at the 1st visit did not improve the persistence and compliance of the patients for bisphosphonate treatment.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC3856379:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "Osteoporosis is defined by the World Health Organization (WHO) as a bone mineral density of 2.5 standard deviations or more below the mean peak bone mass",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC3856379:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3856379",
      "text_span_id": null,
      "text": "Clinical trials have shown that osteoporosis treatment by oral bisphosphonates such as alendronate and risedronate is quite effective, increasing bone mass and preventing vertebral fractures",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": null,
      "source": "extracted"
    }
