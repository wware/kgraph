  "evidence_entities": [
    {
      "id": "PMC4480270:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "abstract_1",
      "text": "Apixaban, a novel oral anticoagulant which has been approved for the prevention of stroke and systemic embolism in non-valvular atrial fibrillation, reduces both ischemic and haemorrhagic stroke and produces fewer bleedings than vitamin K antagonist warfarin.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "abstract_2",
      "text": "We performed a cost-effectiveness analysis of apixaban versus warfarin in non-valvular atrial fibrillation (NVAF) in patients suitable for oral anticoagulation in Argentina.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "abstract_3",
      "text": "The study revealed that apixaban is cost-effective compared with warfarin using a willingness to pay threshold ranging from 1 to 3 per capita Gross Domestic Product (11558 \u2013 34664 USD) with an incremental cost-effectiveness ratio of 786.08 USD per QALY gained.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "results_1",
      "text": "In a VKA suitable cohort of 1000 patients with NVAF, compared with warfarin, the use of apixaban resulted in 24 fewer strokes (including first and recurrent ischemic and hemorrhagic) or systemic embolism, 41 fewer major bleeding events (including first and recurrent hemorrhagic stroke, other intracranial hemorrhage and other major bleeds), and 26 fewer cardiovascular-related deaths.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "background_1",
      "text": "Atrial Fibrillation (AF) is one of the most frequent arrhythmias in adult population. It's estimated prevalence is 1 \u2013 2 % in the general population and increases to 10 % in subjects > 65 years old.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:background:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "background_2",
      "text": "It is associated with a 5-fold increase in the risk of stroke and systemic embolic events (i.e. pulmonary embolism and myocardial infarction).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:background:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "background_3",
      "text": "Apixaban, an oral factor Xa inhibitor is the most recent compound to receive medical approval for the prevention of thrombotic events in AF in US and Europe.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    },
    {
      "id": "PMC4480270:background:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC4480270",
      "text_span_id": "background_4",
      "text": "In one clinical trial for apixaban, ARISTOTLE, Apixaban demonstrated that it is superior to dose-adjusted warfarin in patients suitable for oral anticoagulants.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cost-effectiveness analysis",
      "eco_type": "economic evaluation",
      "source": "extracted"
    }
  ],
