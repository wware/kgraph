    {
      "id": "PMC2528071:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2528071",
      "text_span_id": "intro_1",
      "text": "Obesity occurs as a result of white adipose tissue enlargement, caused by adipocyte hyperplasia and/or hypertrophy",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2528071:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2528071",
      "text_span_id": "intro_2",
      "text": "dysregulated production of adipokines has been found to participate in the development of metabolic and vascular diseases related to obesity",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2528071:adiponectin:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2528071",
      "text_span_id": "adiponectin_1",
      "text": "Unlike most adipokines, adiponectin mRNA in WAT and serum levels are decreased in obesity",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2528071:adiponectin:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2528071",
      "text_span_id": "adiponectin_2",
      "text": "Plasma concentrations are negatively correlated with body mass index (BMI)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "Review",
      "eco_type": null,
      "source": "extracted"
    },
