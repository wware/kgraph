  "evidence_entities": [
    {
      "id": "PMC6728296:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6728296",
      "text_span_id": "methods_1",
      "text": "Adults (\u2265 18 years) were eligible for the validation study if they had a diagnosis of acromegaly confirmed by IGF-1 levels above the age-adjusted upper limit of normal (ULN), random GH levels > 1.0 \u00b5g/L (patients with diabetes) or lack of suppression of GH levels to < 0.4 \u00b5g/L after a 75 g oral glucose load (patients without diabetes), and a pituitary adenoma visualized with MRI.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "clinical validation study",
      "source": "extracted"
    },
    {
      "id": "PMC6728296:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6728296",
      "text_span_id": "results_2",
      "text": "Of 228 patients enrolled, investigators considered disease to be controlled in 110 (48.2%), not controlled in 105 (46.1%), and yet to be clarified in 13 (5.7%) according to CGE-DC.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "clinical validation study",
      "source": "extracted"
    },
    {
      "id": "PMC6728296:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6728296",
      "text_span_id": "results_3",
      "text": "Among these patients, 110 (81.5%) were on somatostatin receptor ligands (SRLs), 28 (20.7%) were on the growth hormone receptor antagonist (GHRA) pegvisomant, 35 (25.9%) were on dopamine agonists (DAs; predominantly cabergoline), and three (2.2%) were receiving other medications.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "clinical validation study",
      "source": "extracted"
    },
    {
      "id": "PMC6728296:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6728296",
      "text_span_id": "results_4",
      "text": "In the controlled group, 29.7% of patients did not exhibit hormonal control (GH \u2264 2.5 \u00b5g/L; normalized IGF-1) and 47.3% did not have rigorous hormonal control (GH < 1.0 \u00b5g/L; normalized IGF-1) by contemporary consensus.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "clinical validation study",
      "source": "extracted"
    }
  ],
