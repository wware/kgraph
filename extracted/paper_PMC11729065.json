  "evidence_entities": [
    {
      "id": "PMC11729065:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729065",
      "text_span_id": "abstract_1",
      "text": "Polycystic Ovary Syndrome (PCOS) is diagnosed by a combination of three features: hyperandrogenism (biochemical and/or clinical), ovulatory dysfunction, and polycystic ovarian morphology",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "cross-sectional",
      "source": "extracted"
    },
    {
      "id": "PMC11729065:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729065",
      "text_span_id": "results_1",
      "text": "Among OLIGO-ONLY, 19 (26.8%) demonstrated hyperandrogenemia without hirsutism, with White women significantly more likely than Black women to demonstrate this",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "cross-sectional",
      "source": "extracted"
    },
    {
      "id": "PMC11729065:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729065",
      "text_span_id": "introduction_2",
      "text": "The presence of hirsutism has been described as a strong, reliable indicator of androgen excess, with an estimated 65\u201375% prevalence in PCOS patients",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "cross-sectional",
      "source": "extracted"
    },
    {
      "id": "PMC11729065:discussion:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729065",
      "text_span_id": "discussion_3",
      "text": "there is also evidence supporting the role of insulin resistance in this condition",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "cross-sectional",
      "source": "extracted"
    },
    {
      "id": "PMC11729065:discussion:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729065",
      "text_span_id": "discussion_4",
      "text": "the long-term health sequelae of untreated PCOS such as increased risk for endometrial cancer and cardiovascular disease",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "observational",
      "eco_type": "cross-sectional",
      "source": "extracted"
    }
