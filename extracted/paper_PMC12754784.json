  "evidence_entities": [
    {
      "id": "PMC12754784:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_1",
      "text": "The alternative lengthening of telomeres (ALT) pathway is a telomerase-independent telomere maintenance mechanism leveraged by a subset of human cancers.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12754784:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_2",
      "text": "In these tumors, telomere DNA synthesis is achieved via homologous recombination-based mechanisms.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12754784:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_3",
      "text": "ALT-positive tumors harbor distinctive hallmarks, including heterogeneous telomere lengths, the presence of ALT-associated PML bodies, extrachromosomal telomeric repeats, telomere fragility, and mitotic DNA synthesis.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12754784:abstract:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_4",
      "text": "These features reflect underlying replication stress and deregulated DNA repair mechanisms.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12754784:abstract:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_5",
      "text": "ALT is associated with various tumor types and can often contribute to worsening the patient's prognosis.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12754784:abstract:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_6",
      "text": "Strikingly, ALT cancers are particularly enriched in childhood cancers, especially in high-grade gliomas, neuroblastoma, and osteosarcomas, three cancer types that are very common in children.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12754784:abstract:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12754784",
      "text_span_id": "abstract_7",
      "text": "We provide a comprehensive review of the DNA repair factors that drive ALT activation and maintenance and explore emerging therapeutic opportunities associated with the selective dependence of ALT cancer cells on these specific DNA damage response factors.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    }
  ],
