  "evidence_entities": [
    {
      "id": "PMC5844663:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5844663",
      "text_span_id": "abstract_1",
      "text": "This is a rare autosomal-dominant cancer syndrome and the patients with MEN1 are characterized by the occurrence of tumors in multiple endocrine tissues, associated with germline and somatic inactivating mutations in the MEN1 gene.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC5844663:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5844663",
      "text_span_id": "introduction_2",
      "text": "MEN1 is characterized by the occurrence of pancreatic islet, parathyroid, and anterior pituitary tumors.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC5844663:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5844663",
      "text_span_id": "introduction_3",
      "text": "It encodes a 610-amino acid protein, menin, responsible for the inhibition of many transcription factors that regulate cell cycle, cell differentiation and apoptosis",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC5844663:introduction:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5844663",
      "text_span_id": "introduction_4",
      "text": "symptoms may include hypercalcemia leading to urolithiasis; hypoglycemia causing weight loss, mental confusion and dizziness; erectile dysfunction; infertility, amenorrhea in women",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
