  "evidence_entities": [
    {
      "id": "PMC6921696:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6921696",
      "text_span_id": "background_1",
      "text": "Intestinal dysbiosis, or dysbacteriosis, is an abnormal interaction between the intestinal microbiota and the host cells due to altered microbial diversity.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC6921696:background:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6921696",
      "text_span_id": "background_2",
      "text": "This study aimed to investigate the metabolic effects and changes in the intestinal microbiota in newborn rats following exposure to increased levels of maternal androgens in a rat model of maternal polycystic ovary syndrome (PCOS).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC6921696:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6921696",
      "text_span_id": "results_1",
      "text": "Markers of systemic inflammation were significantly increased in the female offspring but not in the male offspring born to rat in the PCOS model.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC6921696:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6921696",
      "text_span_id": "results_2",
      "text": "Following birth, newborn rats that received antibiotics showed an improved metabolic phenotype, with reduced serum lipid levels, insulin resistance, body weight, inflammation of adipose tissue, and serum levels of inflammatory cytokines compared with controls.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC6921696:conclusions:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC6921696",
      "text_span_id": "conclusions_1",
      "text": "In a rat model of maternal PCOS, exposure to androgens in utero resulted in dysbiosis of the intestinal microbiota and metabolic disorders of the newborn female rats.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    }
