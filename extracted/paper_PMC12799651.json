      "text_span_id": "background_1",
      "text": "Postoperative evaluation in patients with acromegaly typically involves measuring insulin-like growth factor 1 (IGF-1) levels and assessing growth hormone (GH) suppression via an oral glucose tolerance test (OGTT).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective observational study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
