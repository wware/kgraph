      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12799651",
      "text_span_id": "results_1",
      "text": "In all Group I patients, delayed normalization of IGF-1 was observed, taking 3 to 5 years.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective observational study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
      "id": "PMC12799651:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12799651",
      "text_span_id": "results_2",
      "text": "In Group II, abnormal GH suppression during OGTT persisted in all patients; however, IGF-1 levels remained within the normal range without re-elevations.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective observational study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
