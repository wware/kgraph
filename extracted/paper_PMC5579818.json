  "evidence_entities": [
    {
      "id": "PMC5579818:case_report:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5579818",
      "text_span_id": "case_report_1",
      "text": "A 19-year-old woman was scheduled to undergo bilateral sagittal split ramus osteotomy after being diagnosed with a jaw deformity. Preoperative electrocardiography (ECG) revealed a junctional rhythm with a slow heart rate (HR).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC5579818:case_report:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5579818",
      "text_span_id": "case_report_2",
      "text": "At 90 minutes after anesthesia induction, local anesthesia with 10 mL of 1% lidocaine and 1:100,000 adrenaline was administered. A junctional rhythm appeared 15 minutes after the local anesthesia.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC5579818:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5579818",
      "text_span_id": "discussion_1",
      "text": "We believe that the atrioventricular nodal pacemaker cells accelerated because of the increased sympathetic activity due to the adrenaline.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC5579818:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC5579818",
      "text_span_id": "discussion_2",
      "text": "On the preoperative ECG, the junctional rhythm with slow HR appeared as an escaped beat caused by slowing of the primary pacemaker.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    }
