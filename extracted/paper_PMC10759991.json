  "evidence_entities": [
    {
      "id": "PMC10759991:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_1",
      "text": "Breast cancer is heterogeneous and differs substantially across different tumors (intertumor heterogeneity) and even within an individual tumor (intratumor heterogeneity).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_2",
      "text": "Gene-expression profiling has considerably impacted our understanding of breast cancer biology.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_3",
      "text": "Four main \"intrinsic subtypes\" of breast cancer (i.e., luminal A, luminal B, HER2-enriched, and basal-like) have been consistently identified by gene expression, showing significant prognostic and predictive value in multiple clinical scenarios.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_4",
      "text": "Thanks to the molecular profiling of breast tumors, breast cancer is a paradigm of treatment personalization.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_5",
      "text": "Several standardized prognostic gene-expression assays are presently being used in the clinic to guide treatment decisions.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_6",
      "text": "Moreover, the development of single-cell-level resolution molecular profiling has allowed us to appreciate that breast cancer is also heterogeneous within a single tumor.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_7",
      "text": "There is an evident functional heterogeneity within the neoplastic and tumor microenvironment cells.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC10759991:abstract:8:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC10759991",
      "text_span_id": "abstract_8",
      "text": "Finally, emerging insights from these studies suggest a substantial cellular organization of neoplastic and tumor microenvironment cells, thus defining breast cancer ecosystems and highlighting the importance of spatial localizations.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    }
  ],
