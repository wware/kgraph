      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12775414",
      "text_span_id": "results_1",
      "text": "Numerical results demonstrate that MPKGSA excels at balancing convergence and diversity, achieving high prediction accuracy with minimal biomarker subsets.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "computational",
      "eco_type": "computational analysis",
      "source": "extracted"
    },
