  "evidence_entities": [
    {
      "id": "PMC11128938:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "abstract_1",
      "text": "Desmopressin is increasingly used for the diagnosis of Cushing disease (CD) since corticotropin-releasing hormone became unavailable.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "abstract_2",
      "text": "Intravenous desmopressin administration produced no ACTH or cortisol increase.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "abstract_3",
      "text": "Inferior petrosal sinus sampling (IPSS) with desmopressin stimulation resulted in elevated central-to-peripheral ACTH ratio and prolactin co-secretion, while peripheral ACTH remained stable.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "introduction_1",
      "text": "The mechanism by which desmopressin stimulates ACTH secretion in CD may result from overexpression of AVPR1B receptors as well as ectopic AVPR2 receptors in corticotroph adenomas, which is more prevalent in tumors harboring USP8 mutations.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:case:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "case_1",
      "text": "Over the previous 2 years he had developed diabetes, hypertension, hypokalemia, osteoporosis, obesity, and overt Cushingoid appearance.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:treatment:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "treatment_1",
      "text": "However, pathology showed normal pituitary tissue with rare Crooke's cells, suggesting cortisol excess.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:outcome:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "outcome_1",
      "text": "Two weeks later, the patient was admitted to the emergency unit with nausea, vomiting, and lethargy.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:outcome:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "outcome_2",
      "text": "AI was diagnosed, and the patient's condition promptly resolved with IV hydrocortisone and fluid resuscitation.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11128938:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11128938",
      "text_span_id": "discussion_1",
      "text": "A subset of corticotroph adenomas express D2 receptors and their stimulation by dopamine agonists inhibits ACTH secretion.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    }
