  "evidence_entities": [
    {
      "id": "PMC12774523:introduction:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "Breast and thyroid cancers are among the most frequently diagnosed malignancies in women, and studies suggest a potential bidirectional association.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12774523:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "While fluorodeoxyglucose (FDG)-positron emission tomography (PET)/computed tomography (CT) is a valuable imaging modality for evaluating breast cancer, its sensitivity in detecting low-metabolic subtypes remains limited.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12774523:case_report:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "We present a 61-year-old female with a suspected left breast malignancy, suggestive of luminal A subtype, showing low FDG uptake (maximum standardized uptake value [SUVmax] 2.0) on PET/CT",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12774523:discussion:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "The European Association of Nuclear Medicine-Society of Nuclear Medicine and Molecular Imaging 2024 guidelines highlight that FDG-PET/CT is highly effective for triple-negative breast cancer (TNBC) and HER2+ cancers but less so for estrogen receptor-positive (ER + ) tumors (luminal A/B) due to lower glucose metabolism.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12774523:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "Luminal tumors rely on oxidative phosphorylation, whereas TNBC and HER2+ tumors depend on anaerobic glycolysis.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12774523:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "Several studies suggest a bidirectional association between breast and thyroid cancers. Meta-analyses show an increased risk of thyroid cancer following breast cancer (OR 1.55) and vice versa (OR 1.32).",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC12774523:discussion:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12774523",
      "text_span_id": null,
      "text": "Shared genetic mutations (PTEN, BRCA1/2) and hormonal influences (estrogen receptor expression) contribute to this link.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case_report",
      "eco_type": null,
      "source": "extracted"
    }
  ],
