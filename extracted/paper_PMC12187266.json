    {
      "id": "PMC12187266:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "background_1",
      "text": "Cushing syndrome (CS) is a rare endocrine disorder characterized by excessive secretion of glucocorticoids, leading to a variety of clinical manifestations, comorbidities, and increased mortality despite treatment.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
      "id": "PMC12187266:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "methods_1",
      "text": "In this paper, we explore the potential of state-of-the-art machine learning algorithms as a clinical decision support system for analyzing and classifying CS.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
      "id": "PMC12187266:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "results_1",
      "text": "We developed a linear mathematical model with high predictive ability, achieving a classification accuracy of 97.03% and a Kappa value of 94.05%.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
      "id": "PMC12187266:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "introduction_1",
      "text": "Cushing syndrome (CS) is a potentially fatal disease caused by abnormally high levels of the cortisol hormone, first described by Harvey Cushing in 1912.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
      "id": "PMC12187266:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "introduction_2",
      "text": "In pituitary-induced Cushing (PC), excessive secretion of ACTH stimulates the adrenal glands to produce cortisol.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": "clinical study",
      "source": "extracted"
    },
    {
      "id": "PMC12187266:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC12187266",
      "text_span_id": "introduction_3",
      "text": "Ectopic CS (EC) occurs when tumors located outside the pituitary gland, such as those in the pancreas, lungs or thyroid produce ACTH.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": "clinical study",
      "source": "extracted"
    }
