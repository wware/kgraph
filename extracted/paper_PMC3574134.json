  "evidence_entities": [
    {
      "id": "PMC3574134:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3574134",
      "text_span_id": "abstract_1",
      "text": "Using an ovine model of polycystic ovary syndrome (PCOS), (pregnant ewes injected with testosterone propionate (TP) (100 mg twice weekly) from day (d)62 to d102 of d147 gestation (maternal injection \u2013 MI-TP)), we previously reported female offspring with normal glucose tolerance but hyperinsulinemia.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3574134:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3574134",
      "text_span_id": "abstract_2",
      "text": "In female d62MI-TP offspring insulin signalling was unaltered but there was a pancreatic phenotype with increased numbers of \u03b2-cells (P<0.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3574134:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3574134",
      "text_span_id": "abstract_3",
      "text": "The fetal pancreas expressed androgen receptors in islets and genes involved in \u03b2-cell development and function (PDX1, IGF1R, INSR and INS) were up-regulated in female fetuses after d62MI-TP treatment (P<0.05\u20130.01).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3574134:abstract:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3574134",
      "text_span_id": "abstract_4",
      "text": "FI-TP (commencing d62) (not FI-DES treatment) caused elevated basal insulin secretion in vitro and the genes altered by d62MI-TP treatment were similarly altered by FI-TP but not FI-DES.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC3574134:conclusion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3574134",
      "text_span_id": "conclusion_1",
      "text": "In conclusion, androgen over-exposure alters fetal pancreatic development and \u03b2-cell numbers in offspring.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    }
  ],
