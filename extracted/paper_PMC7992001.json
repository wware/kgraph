  "evidence_entities": [
    {
      "id": "PMC7992001:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC7992001",
      "text_span_id": "results_1",
      "text": "An increase in plasma vitellogenin was observed in fish exposed to the high dose of bisphenol A for 2 weeks.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC7992001:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC7992001",
      "text_span_id": "results_2",
      "text": "At this experimental time the level of the thyroid hormone triiodothyronine (T3) in plasma was elevated after bisphenol S exposure at the high concentration, and paralleled by an increase of micronucleated cells.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC7992001:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC7992001",
      "text_span_id": "results_3",
      "text": "Moreover, bisphenol A induced an increase of micronuclei frequency in fish erythrocytes after the exposure at the lowest dose tested.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC7992001:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC7992001",
      "text_span_id": "discussion_1",
      "text": "Taken together the results indicate that both bisphenol A and its alternative bisphenol S cause endocrine disrupting and genotoxic effects in brown trout, although suggesting two different mechanisms of damage underlying bisphenol A and bisphenol S activity.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    }
