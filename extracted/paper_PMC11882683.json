  "evidence_entities": [
    {
      "id": "PMC11882683:summary:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11882683",
      "text_span_id": null,
      "text": "Romosozumab demonstrated the most significant improvements in bone mineral density, particularly in the lumbar spine and total hip, by reducing bone resorption and increasing bone formation markers.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11882683:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11882683",
      "text_span_id": null,
      "text": "Following the switch from BP, the ROMO group demonstrated a dual effect of decreased bone resorption and increased bone formation markers.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11882683:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11882683",
      "text_span_id": null,
      "text": "After 12 months, the ROMO group demonstrated significantly greater BMD increases in the LS (11.4%) compared to the DMAb (6.3%; p < 0.001) and TPTD (5.9%; p < 0.001) groups.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC11882683:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11882683",
      "text_span_id": null,
      "text": "By inhibiting sclerostin, ROMO stimulates bone formation through activating Wnt signaling in osteoblasts, and indirectly reduces bone resorption by enhancing osteoprotegerin production in both osteoblasts and osteocytes",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
