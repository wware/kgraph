  "evidence_entities": [
    {
      "id": "PMC2874930:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2874930",
      "text_span_id": "intro_1",
      "text": "There is increasing evidence that obesity in humans is associated with low-level inflammation",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2874930:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2874930",
      "text_span_id": "intro_2",
      "text": "the increase in visceral omental rather than abdominal subcutaneous adipose tissue best correlates with measures of insulin resistance",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2874930:section3:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2874930",
      "text_span_id": "section3_1",
      "text": "leptin was found to be released exclusively by the fat cells, while TNF\u03b1, hepatocyte growth factor (HGF), IL-10, IL-1\u03b2, PGE2, IL-6, vascular endothelial growth factor (VEGF) and interleukin 8 (IL-8) were primarily released by the nonfat cells",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2874930:section6:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2874930",
      "text_span_id": "section6_1",
      "text": "There was enhanced release of endothelin-1, lipocalin-2, visfatin, GPX-3, and FABP-4 by the most obese women as compared to that by women in the bottom tertile",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2874930:section9:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2874930",
      "text_span_id": "section9_1",
      "text": "the toll-like receptor 4 (TLR-4), that plays an important role in innate immunity through its ability to recognize bacterial lipopolysaccharides, has been postulated to play a role in the obesity-induced inflammatory response",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC2874930:section10:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC2874930",
      "text_span_id": "section10_1",
      "text": "The best evidence for the 'hypoxia hypothesis' is the evidence that adipose tissue is poorly oxygenated in the obese",
      "confidence": 0.9,
      "extraction_method": "llm",
