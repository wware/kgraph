      "text_span_id": null,
      "text": "The curative effect of bisphosphonic acid group was better than that of control group",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "clinical trial",
      "eco_type": null,
      "source": "extracted"
    },
