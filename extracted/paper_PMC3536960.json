  "evidence_entities": [
    {
      "id": "PMC3536960:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3536960",
      "text_span_id": "abstract_1",
      "text": "Bone mineral density response to once weekly delayed-release formulation of risedronate, given before or following breakfast, was non-inferior to that seen with traditional immediate-release risedronate given daily before breakfast.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": "clinical trial",
      "source": "extracted"
    },
    {
      "id": "PMC3536960:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3536960",
      "text_span_id": "results_1",
      "text": "After 2 years of treatment, BMD increases at the lumbar spine and total hip with the weekly DR doses similar to or greater than that with the IR daily dose.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": "clinical trial",
      "source": "extracted"
    },
    {
      "id": "PMC3536960:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC3536960",
      "text_span_id": "results_2",
      "text": "Decreases in BTMs were similar or significantly lower in the DR groups.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "randomized controlled trial",
      "eco_type": "clinical trial",
      "source": "extracted"
