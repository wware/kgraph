      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC7433060",
      "text_span_id": "results_2",
      "text": "The combination therapy did not significantly change patients' fasting plasma glucose while decreasing the fasting plasma insulin.",
      "confidence": 0.95,
