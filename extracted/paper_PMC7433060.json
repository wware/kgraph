      "entity_id": null,
      "paper_id": "PMC7433060",
      "text_span_id": "results_1",
      "text": "The overall rate of serum insulin-like growth factor 1 (IGF-1) normalization was 66% (95% CI: 52\u201378%; I2 = 62.59%).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "meta-analysis",
      "eco_type": "systematic review",
      "source": "extracted"
    },
